}
# Visualize the results using a Forest Plot
p_forest <- ggplot(model_results, aes(x = reorder(term, Odds_Ratio), y = Odds_Ratio, color = Significant)) +
geom_point(size = 3) +
geom_errorbar(aes(ymin = Conf_Low, ymax = Conf_High), width = 0.2) +
geom_hline(yintercept = 1, linetype = "dashed", color = "red", size = 0.8) +
coord_flip() +
scale_color_manual(values = c("Yes" = "#2ecc71", "No" = "gray60")) +
labs(
title = "Key Drivers of Customer Conversion (Logistic Regression)",
subtitle = "Odds Ratios with 95% Confidence Intervals",
x = "Features",
y = "Odds Ratio (Impact on Conversion)"
) +
theme_minimal(base_size = 14) +
theme(
legend.position = "bottom",
panel.grid.minor = element_blank()
)
# Save and display the plot
ggsave("plots/13_statistical_drivers_forest.png", plot = p_forest, width = 10, height = 8, bg = "white")
print(p_forest)
