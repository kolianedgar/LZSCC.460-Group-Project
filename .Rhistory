best_model <- model_A
best_eval  <- eval_A
best_label <- "Model A (obs_weights only)"
best_tune  <- tune_A
} else {
best_model <- model_B
best_eval  <- eval_B
best_label <- "Model B (obs_weights + spw)"
best_tune  <- tune_B
}
cat(sprintf("\nBest model: %s (AUC-ROC = %.4f)\n", best_label, auc(best_eval$roc_obj)))
# ------------------------------------------------------------------------------
# 8. Feature Importance (Best Model)
# ------------------------------------------------------------------------------
cat("\n=== FEATURE IMPORTANCE ===\n")
importance <- xgb.importance(
feature_names = colnames(X_train),
model         = best_model
)
cat("\nTop 10 features by Gain:\n")
print(head(importance, 10))
imp_top <- importance[1:min(15, nrow(importance)), ]
imp_top$Feature <- factor(imp_top$Feature, levels = rev(imp_top$Feature))
p_importance <- ggplot(imp_top, aes(x = Feature, y = Gain)) +
geom_col(fill = "#2563eb") +
coord_flip() +
labs(title = paste("Feature Importance (Gain) -", best_label),
x = NULL, y = "Gain") +
theme_minimal()
ggsave("plots/xgboost/feature_importance.png",
p_importance, width = 10, height = 6, dpi = 150)
# ------------------------------------------------------------------------------
# 9. SHAP Analysis (Best Model)
# ------------------------------------------------------------------------------
cat("\n=== SHAP ANALYSIS ===\n")
set.seed(123)
shap_n   <- min(500, nrow(X_train))
shap_idx <- sample(seq_len(nrow(X_train)), shap_n)
shap_values <- shap.values(
xgb_model = best_model,
X_train   = X_train[shap_idx, ]
)
shap_long <- shap.prep(
shap_contrib = shap_values$shap_score,
X_train      = as.data.frame(X_train[shap_idx, ])
)
p_shap <- shap.plot.summary(shap_long) +
ggtitle(paste("SHAP Summary -", best_label)) +
theme_minimal()
ggsave("plots/xgboost/shap_summary.png",
p_shap, width = 10, height = 7, dpi = 150)
cat("\nTop 10 features by mean |SHAP|:\n")
print(head(sort(shap_values$mean_shap_score, decreasing = TRUE), 10))
# ------------------------------------------------------------------------------
# 10. Diagnostic Plots
# ------------------------------------------------------------------------------
cat("\n=== GENERATING DIAGNOSTIC PLOTS ===\n")
# --- 10a. ROC comparison (both models) ---
png("plots/xgboost/roc_comparison.png", width = 800, height = 600)
plot(eval_A$roc_obj,
main = "ROC Comparison: Model A vs Model B",
col  = "#2563eb", lwd = 2)
plot(eval_B$roc_obj, add = TRUE, col = "#f59e0b", lwd = 2)
legend("bottomright",
legend = c(
sprintf("A: obs_weights (AUC = %.3f)", auc(eval_A$roc_obj)),
sprintf("B: obs_weights + spw (AUC = %.3f)", auc(eval_B$roc_obj))
),
col = c("#2563eb", "#f59e0b"),
lwd = 2)
abline(a = 0, b = 1, lty = 2, col = "grey50")
dev.off()
# --- 10b. ROC curve (best model only) ---
png("plots/xgboost/roc_curve.png", width = 800, height = 600)
plot(best_eval$roc_obj,
main = paste("ROC Curve -", best_label),
col  = "#2563eb", lwd = 2,
print.auc = TRUE, print.auc.x = 0.4, print.auc.y = 0.2)
abline(a = 0, b = 1, lty = 2, col = "grey50")
dev.off()
# --- 10c. Threshold vs F1 (both models) ---
p_thresh <- ggplot() +
geom_line(
data = data.frame(t = eval_A$thresholds, f1 = eval_A$f1_scores, model = "A: obs_weights"),
aes(x = t, y = f1, colour = model), linewidth = 1
) +
geom_line(
data = data.frame(t = eval_B$thresholds, f1 = eval_B$f1_scores, model = "B: obs_weights + spw"),
aes(x = t, y = f1, colour = model), linewidth = 1
) +
geom_vline(xintercept = eval_A$opt_thresh, linetype = "dashed", colour = "#2563eb", alpha = 0.6) +
geom_vline(xintercept = eval_B$opt_thresh, linetype = "dashed", colour = "#f59e0b", alpha = 0.6) +
scale_colour_manual(values = c("A: obs_weights" = "#2563eb", "B: obs_weights + spw" = "#f59e0b")) +
labs(title = "F1 Score vs Decision Threshold",
x = "Threshold", y = "F1 Score", colour = "Model") +
theme_minimal()
ggsave("plots/xgboost/threshold_vs_f1.png", p_thresh, width = 9, height = 5, dpi = 150)
# --- 10d. Predicted probability distributions (both models) ---
prob_df <- rbind(
data.frame(prob = eval_A$probs, actual = factor(y_test_num), model = "A: obs_weights"),
data.frame(prob = eval_B$probs, actual = factor(y_test_num), model = "B: obs_weights + spw")
)
p_probs <- ggplot(prob_df, aes(x = prob, fill = actual)) +
geom_histogram(bins = 50, alpha = 0.6, position = "identity") +
facet_wrap(~model, ncol = 1) +
scale_fill_manual(
values = c("0" = "#ef4444", "1" = "#2563eb"),
labels = c("0" = "Non-converter", "1" = "Converter")
) +
labs(title = "Predicted Probability Distribution by Actual Class",
x = "Predicted P(Conversion = 1)", y = "Count", fill = "Actual Class") +
theme_minimal()
ggsave("plots/xgboost/probability_distribution.png", p_probs, width = 9, height = 7, dpi = 150)
# --- 10e. Tuning convergence (both models) ---
tune_df <- rbind(
data.frame(tune_A$results, model = "A: obs_weights"),
data.frame(tune_B$results, model = "B: obs_weights + spw")
)
best_points <- rbind(
data.frame(tune_A$results[tune_A$best_idx, ], model = "A: obs_weights"),
data.frame(tune_B$results[tune_B$best_idx, ], model = "B: obs_weights + spw")
)
p_tuning <- ggplot(tune_df, aes(x = iter, y = cv_logloss_mean, colour = model)) +
geom_point(alpha = 0.5, size = 2) +
geom_point(data = best_points, size = 4, shape = 18) +
scale_colour_manual(values = c("A: obs_weights" = "#2563eb", "B: obs_weights + spw" = "#f59e0b")) +
labs(title = "Random Search: CV Log Loss per Iteration",
x = "Iteration", y = "CV Log Loss (5-fold mean)", colour = "Model") +
theme_minimal()
ggsave("plots/xgboost/tuning_convergence.png", p_tuning, width = 9, height = 5, dpi = 150)
# ------------------------------------------------------------------------------
# 11. Save Models and Results
# ------------------------------------------------------------------------------
xgb.save(model_A, "plots/xgboost/model_A.json")
xgb.save(model_B, "plots/xgboost/model_B.json")
# Save best model hyperparameters
best_hp_df <- data.frame(
parameter = c("eta", "max_depth", "min_child_weight", "subsample",
"colsample_bytree", "gamma", "nrounds", "scale_pos_weight",
"uses_obs_weights"),
model_A = c(tune_A$best_hp$eta, tune_A$best_hp$max_depth,
tune_A$best_hp$min_child_weight, tune_A$best_hp$subsample,
tune_A$best_hp$colsample_bytree, tune_A$best_hp$gamma,
tune_A$best_hp$best_nrounds, NA, TRUE),
model_B = c(tune_B$best_hp$eta, tune_B$best_hp$max_depth,
tune_B$best_hp$min_child_weight, tune_B$best_hp$subsample,
tune_B$best_hp$colsample_bytree, tune_B$best_hp$gamma,
tune_B$best_hp$best_nrounds, spw, TRUE)
)
write.csv(best_hp_df, "plots/xgboost/hyperparameters.csv", row.names = FALSE)
cat("\n=== COMPLETE ===\n")
cat("All outputs saved to plots/xgboost/\n")
cat("Files:\n")
cat("  - model_comparison.csv         (A vs B metrics)\n")
cat("  - hyperparameters.csv          (best configs for both)\n")
cat("  - tuning_results_A.csv         (50 iterations, Model A)\n")
cat("  - tuning_results_B.csv         (50 iterations, Model B)\n")
cat("  - model_A.json / model_B.json  (serialised models)\n")
cat("  - feature_importance.png       (best model, gain-based)\n")
cat("  - shap_summary.png             (best model, SHAP beeswarm)\n")
cat("  - roc_comparison.png           (A vs B ROC overlay)\n")
cat("  - roc_curve.png                (best model ROC)\n")
cat("  - threshold_vs_f1.png          (A vs B threshold curves)\n")
cat("  - probability_distribution.png (A vs B pred distributions)\n")
cat("  - tuning_convergence.png       (A vs B search progress)\n")
# ==============================================================================
# 04_xgboost.R
# XGBoost Predictive Model for Customer Conversion
# LZSCC.460 Group Project - Objective 4
#
# Two model variants compared:
#   Model A: observation weights only
#   Model B: observation weights + scale_pos_weight
# ==============================================================================
## Library Implementation Stage
library(xgboost)
library(dplyr)
library(caret)
library(pROC)
library(ggplot2)
library(SHAPforxgboost)
## Setup Stage
setwd("C:/Users/sejdi/Desktop/Lancaster University Masters - Leipzig/Data Science Fundamentals/LZSCC.460-Group-Project")
source("utils/utils_preprocessing.R")
source("utils/utils.R")
source("01_preprocessing.R")
if (!dir.exists("plots/xgboost")) dir.create("plots/xgboost", recursive = TRUE)
## Importing & Preprocessing Stage
# Uses preprocess_data() which handles: duplicate removal, ID removal,
# ConversionRate filtering, stratified split, imputation, outlier capping,
# encoding, matrix conversion, and class weight computation.
raw_data <- read.csv("marketing.csv")
processed <- preprocess_data(
data        = raw_data,
target_col  = "Conversion",
id_cols     = "CustomerID",
filter_col  = "ConversionRate",
filter_min  = 0,
filter_max  = 1,
train_prop  = 0.8,
stratify    = TRUE,
seed        = 123,
model_type  = "xgb"
)
X_train     <- processed$X_train
y_train     <- as.numeric(as.character(processed$y_train))
X_test      <- processed$X_test
y_test      <- as.numeric(as.character(processed$y_test))
obs_weights <- processed$obs_weights
cat("Train size:", dim(X_train), "\n")
cat("Test size: ", dim(X_test), "\n")
## Class Imbalance Setup
n_pos <- sum(y_train == 1)
n_neg <- sum(y_train == 0)
spw   <- n_neg / n_pos
cat("\nClass 0 (non-converters):", n_neg, sprintf("(%.1f%%)", 100 * n_neg / length(y_train)))
cat("\nClass 1 (converters):    ", n_pos, sprintf("(%.1f%%)", 100 * n_pos / length(y_train)))
cat("\nscale_pos_weight:        ", round(spw, 4), "\n")
# DMatrix with observation weights (used by both models)
dtrain <- xgb.DMatrix(data = X_train, label = y_train, weight = obs_weights)
dtest  <- xgb.DMatrix(data = X_test,  label = y_test)
## Hyperparameter Tuning Stage (Random Search)
# All hyperparameters are determined here via random search with 5-fold CV.
# Following Bergstra & Bengio (2012): random search is more efficient
# than grid search in high-dimensional hyperparameter spaces.
set.seed(42)
n_iter <- 50
search_space <- data.frame(
eta              = runif(n_iter, 0.01, 0.3),
max_depth        = sample(3:10, n_iter, replace = TRUE),
min_child_weight = sample(1:10, n_iter, replace = TRUE),
subsample        = runif(n_iter, 0.5, 1.0),
colsample_bytree = runif(n_iter, 0.5, 1.0),
gamma            = runif(n_iter, 0, 5)
)
# Helper: runs random search for a given model configuration
run_tuning <- function(dtrain, search_space, spw_value = NULL, label = "Model") {
n <- nrow(search_space)
results <- data.frame(
iter = 1:n, eta = numeric(n), max_depth = integer(n),
min_child_weight = integer(n), subsample = numeric(n),
colsample_bytree = numeric(n), gamma = numeric(n),
best_nrounds = integer(n), cv_logloss = numeric(n)
)
cat(sprintf("\nTuning %s (%d iterations)...\n", label, n))
for (i in seq_len(n)) {
params_i <- list(
objective = "binary:logistic", eval_metric = "logloss",
eta = search_space$eta[i], max_depth = search_space$max_depth[i],
min_child_weight = search_space$min_child_weight[i],
subsample = search_space$subsample[i],
colsample_bytree = search_space$colsample_bytree[i],
gamma = search_space$gamma[i],
nthread = parallel::detectCores() - 1
)
if (!is.null(spw_value)) params_i$scale_pos_weight <- spw_value
set.seed(123)
cv <- xgb.cv(params = params_i, data = dtrain, nrounds = 1000,
nfold = 5, stratified = TRUE, early_stopping_rounds = 30,
verbose = 0)
iter_best <- cv$early_stop$best_iteration
log_col   <- grep("test.*logloss_mean", names(cv$evaluation_log), value = TRUE)[1]
results[i, ] <- list(i, search_space$eta[i], search_space$max_depth[i],
search_space$min_child_weight[i], search_space$subsample[i],
search_space$colsample_bytree[i], search_space$gamma[i],
iter_best, cv$evaluation_log[[log_col]][iter_best])
if (i %% 10 == 0) cat(sprintf("  [%d/%d] Best so far: %.4f\n", i, n, min(results$cv_logloss[1:i])))
}
best <- results[which.min(results$cv_logloss), ]
cat(sprintf("  Best: eta=%.3f, depth=%d, nrounds=%d, logloss=%.4f\n",
best$eta, best$max_depth, best$best_nrounds, best$cv_logloss))
list(results = results, best = best)
}
tune_A <- run_tuning(dtrain, search_space, spw_value = NULL, label = "Model A (obs_weights only)")
# ==============================================================================
# 04_xgboost.R
# XGBoost Predictive Model for Customer Conversion
# LZSCC.460 Group Project - Objective 4
#
# Two model variants compared:
#   Model A: observation weights only
#   Model B: observation weights + scale_pos_weight
# ==============================================================================
## Library Implementation Stage
library(xgboost)
library(dplyr)
library(caret)
library(pROC)
library(ggplot2)
library(SHAPforxgboost)
## Setup Stage
setwd("C:/Users/sejdi/Desktop/Lancaster University Masters - Leipzig/Data Science Fundamentals/LZSCC.460-Group-Project")
source("utils/utils_preprocessing.R")
source("utils/utils.R")
source("01_preprocessing.R")
if (!dir.exists("plots/xgboost")) dir.create("plots/xgboost", recursive = TRUE)
## Importing & Preprocessing Stage
# Uses preprocess_data() which handles: duplicate removal, ID removal,
# ConversionRate filtering, stratified split, imputation, outlier capping,
# encoding, matrix conversion, and class weight computation.
raw_data <- read.csv("marketing.csv")
processed <- preprocess_data(
data        = raw_data,
target_col  = "Conversion",
id_cols     = "CustomerID",
filter_col  = "ConversionRate",
filter_min  = 0,
filter_max  = 1,
train_prop  = 0.8,
stratify    = TRUE,
seed        = 123,
model_type  = "xgb"
)
X_train     <- processed$X_train
y_train     <- as.numeric(as.character(processed$y_train))
X_test      <- processed$X_test
y_test      <- as.numeric(as.character(processed$y_test))
obs_weights <- processed$obs_weights
cat("Train size:", dim(X_train), "\n")
cat("Test size: ", dim(X_test), "\n")
## Class Imbalance Setup
n_pos <- sum(y_train == 1)
n_neg <- sum(y_train == 0)
spw   <- n_neg / n_pos
cat("\nClass 0 (non-converters):", n_neg, sprintf("(%.1f%%)", 100 * n_neg / length(y_train)))
cat("\nClass 1 (converters):    ", n_pos, sprintf("(%.1f%%)", 100 * n_pos / length(y_train)))
cat("\nscale_pos_weight:        ", round(spw, 4), "\n")
# DMatrix with observation weights (used by both models)
dtrain <- xgb.DMatrix(data = X_train, label = y_train, weight = obs_weights)
dtest  <- xgb.DMatrix(data = X_test,  label = y_test)
## Hyperparameter Tuning Stage (Random Search)
# All hyperparameters are determined here via random search with 5-fold CV.
# Following Bergstra & Bengio (2012): random search is more efficient
# than grid search in high-dimensional hyperparameter spaces.
set.seed(42)
n_iter <- 50
search_space <- data.frame(
eta              = runif(n_iter, 0.01, 0.3),
max_depth        = sample(3:10, n_iter, replace = TRUE),
min_child_weight = sample(1:10, n_iter, replace = TRUE),
subsample        = runif(n_iter, 0.5, 1.0),
colsample_bytree = runif(n_iter, 0.5, 1.0),
gamma            = runif(n_iter, 0, 5)
)
# Helper: runs random search for a given model configuration
run_tuning <- function(dtrain, search_space, spw_value = NULL, label = "Model") {
n <- nrow(search_space)
results <- data.frame(
iter = 1:n, eta = numeric(n), max_depth = integer(n),
min_child_weight = integer(n), subsample = numeric(n),
colsample_bytree = numeric(n), gamma = numeric(n),
best_nrounds = integer(n), cv_logloss = numeric(n)
)
cat(sprintf("\nTuning %s (%d iterations)...\n", label, n))
for (i in seq_len(n)) {
params_i <- list(
objective = "binary:logistic", eval_metric = "logloss",
eta = search_space$eta[i], max_depth = search_space$max_depth[i],
min_child_weight = search_space$min_child_weight[i],
subsample = search_space$subsample[i],
colsample_bytree = search_space$colsample_bytree[i],
gamma = search_space$gamma[i],
nthread = parallel::detectCores() - 1
)
if (!is.null(spw_value)) params_i$scale_pos_weight <- spw_value
set.seed(123)
cv <- xgb.cv(params = params_i, data = dtrain, nrounds = 1000,
nfold = 5, stratified = TRUE, early_stopping_rounds = 30,
verbose = 0)
iter_best <- cv$early_stop$best_iteration
log_col   <- grep("test.*logloss_mean", names(cv$evaluation_log), value = TRUE)[1]
results[i, ] <- list(i, search_space$eta[i], search_space$max_depth[i],
search_space$min_child_weight[i], search_space$subsample[i],
search_space$colsample_bytree[i], search_space$gamma[i],
iter_best, cv$evaluation_log[[log_col]][iter_best])
if (i %% 10 == 0) cat(sprintf("  [%d/%d] Best so far: %.4f\n", i, n, min(results$cv_logloss[1:i])))
}
best <- results[which.min(results$cv_logloss), ]
cat(sprintf("  Best: eta=%.3f, depth=%d, nrounds=%d, logloss=%.4f\n",
best$eta, best$max_depth, best$best_nrounds, best$cv_logloss))
list(results = results, best = best)
}
tune_A <- run_tuning(dtrain, search_space, spw_value = NULL, label = "Model A (obs_weights only)")
tune_B <- run_tuning(dtrain, search_space, spw_value = spw,  label = "Model B (obs_weights + spw)")
write.csv(tune_A$results, "plots/xgboost/tuning_results_A.csv", row.names = FALSE)
write.csv(tune_B$results, "plots/xgboost/tuning_results_B.csv", row.names = FALSE)
## Training Final Models Stage
# Model A: obs_weights only
params_A <- list(
objective = "binary:logistic", eval_metric = "logloss",
eta = tune_A$best$eta, max_depth = tune_A$best$max_depth,
min_child_weight = tune_A$best$min_child_weight,
subsample = tune_A$best$subsample,
colsample_bytree = tune_A$best$colsample_bytree,
gamma = tune_A$best$gamma,
nthread = parallel::detectCores() - 1
)
model_A <- xgb.train(params = params_A, data = dtrain,
nrounds = tune_A$best$best_nrounds,
evals = list(train = dtrain, test = dtest), verbose = 0)
# Model B: obs_weights + scale_pos_weight
params_B <- params_A
params_B$eta              <- tune_B$best$eta
params_B$max_depth        <- tune_B$best$max_depth
params_B$min_child_weight <- tune_B$best$min_child_weight
params_B$subsample        <- tune_B$best$subsample
params_B$colsample_bytree <- tune_B$best$colsample_bytree
params_B$gamma            <- tune_B$best$gamma
params_B$scale_pos_weight <- spw
model_B <- xgb.train(params = params_B, data = dtrain,
nrounds = tune_B$best$best_nrounds,
evals = list(train = dtrain, test = dtest), verbose = 0)
## Evaluation Stage
evaluate <- function(model, dtest, y_actual, label) {
probs <- predict(model, dtest)
preds <- ifelse(probs > 0.5, 1, 0)
cm  <- confusionMatrix(factor(preds, levels = c("0","1")),
factor(y_actual, levels = c("0","1")), positive = "1")
roc <- roc(y_actual, probs, quiet = TRUE)
cat(sprintf("\n%s\n", label))
cat(sprintf("  AUC-ROC:     %.4f\n", auc(roc)))
cat(sprintf("  Accuracy:    %.4f\n", cm$overall["Accuracy"]))
cat(sprintf("  Sensitivity: %.4f\n", cm$byClass["Sensitivity"]))
cat(sprintf("  Specificity: %.4f\n", cm$byClass["Specificity"]))
cat(sprintf("  F1:          %.4f\n", cm$byClass["F1"]))
cat("\nConfusion Matrix:\n")
print(cm$table)
list(probs = probs, cm = cm, roc = roc)
}
cat("\n=== TEST PERFORMANCE ===\n")
eval_A <- evaluate(model_A, dtest, y_test, "Model A (obs_weights only)")
eval_B <- evaluate(model_B, dtest, y_test, "Model B (obs_weights + spw)")
# Comparison table
comparison <- data.frame(
Model       = c("A: obs_weights", "B: obs_weights + spw"),
AUC_ROC     = round(c(auc(eval_A$roc), auc(eval_B$roc)), 4),
Accuracy    = round(c(eval_A$cm$overall["Accuracy"],    eval_B$cm$overall["Accuracy"]), 4),
Sensitivity = round(c(eval_A$cm$byClass["Sensitivity"], eval_B$cm$byClass["Sensitivity"]), 4),
Specificity = round(c(eval_A$cm$byClass["Specificity"], eval_B$cm$byClass["Specificity"]), 4),
F1          = round(c(eval_A$cm$byClass["F1"],          eval_B$cm$byClass["F1"]), 4)
)
cat("\n=== MODEL COMPARISON ===\n")
print(comparison, row.names = FALSE)
write.csv(comparison, "plots/xgboost/model_comparison.csv", row.names = FALSE)
## Feature Importance Stage
imp_A <- xgb.importance(feature_names = colnames(X_train), model = model_A)
imp_B <- xgb.importance(feature_names = colnames(X_train), model = model_B)
cat("\nModel A - Top 10 by Gain:\n"); print(head(imp_A, 10))
cat("\nModel B - Top 10 by Gain:\n"); print(head(imp_B, 10))
# Plot helper
plot_importance <- function(imp, title, filename) {
imp_top <- imp[1:min(15, nrow(imp)), ]
imp_top$Feature <- factor(imp_top$Feature, levels = rev(imp_top$Feature))
p <- ggplot(imp_top, aes(x = Feature, y = Gain)) +
geom_col(fill = "#2563eb") + coord_flip() +
labs(title = title, x = NULL, y = "Gain") + theme_minimal()
ggsave(filename, p, width = 10, height = 6, dpi = 150)
}
plot_importance(imp_A, "Feature Importance - Model A", "plots/xgboost/importance_A.png")
plot_importance(imp_B, "Feature Importance - Model B", "plots/xgboost/importance_B.png")
## SHAP Interpretability Stage
# SHAP values explain how each feature contributes to individual predictions.
# Following Lundberg & Lee (2017).
# Model A SHAP (full training set)
shap_A <- shap.values(xgb_model = model_A, X_train = X_train)
shap_long_A <- shap.prep(shap_contrib = shap_A$shap_score,
X_train = as.data.frame(X_train))
p_shap_A <- shap.plot.summary(shap_long_A) +
ggtitle("SHAP Summary - Model A (obs_weights only)") + theme_minimal()
ggsave("plots/xgboost/shap_A.png", p_shap_A, width = 10, height = 7, dpi = 150)
cat("\nModel A - Top 10 by mean |SHAP|:\n")
print(head(sort(shap_A$mean_shap_score, decreasing = TRUE), 10))
# Model B SHAP (full training set)
shap_B <- shap.values(xgb_model = model_B, X_train = X_train)
shap_long_B <- shap.prep(shap_contrib = shap_B$shap_score,
X_train = as.data.frame(X_train))
p_shap_B <- shap.plot.summary(shap_long_B) +
ggtitle("SHAP Summary - Model B (obs_weights + spw)") + theme_minimal()
ggsave("plots/xgboost/shap_B.png", p_shap_B, width = 10, height = 7, dpi = 150)
cat("\nModel B - Top 10 by mean |SHAP|:\n")
print(head(sort(shap_B$mean_shap_score, decreasing = TRUE), 10))
## Visualisation Stage
# ROC Comparison
png("plots/xgboost/roc_comparison.png", width = 800, height = 600)
plot(eval_A$roc, col = "#2563eb", lwd = 2,
main = "ROC Comparison: Model A vs Model B")
plot(eval_B$roc, add = TRUE, col = "#f59e0b", lwd = 2)
legend("bottomright",
legend = c(sprintf("A: obs_weights (AUC=%.3f)", auc(eval_A$roc)),
sprintf("B: obs_weights+spw (AUC=%.3f)", auc(eval_B$roc))),
col = c("#2563eb", "#f59e0b"), lwd = 2)
abline(a = 0, b = 1, lty = 2, col = "grey50")
dev.off()
# Predicted probability distributions
prob_df <- rbind(
data.frame(prob = eval_A$probs, actual = factor(y_test), model = "A: obs_weights"),
data.frame(prob = eval_B$probs, actual = factor(y_test), model = "B: obs_weights + spw")
)
p_probs <- ggplot(prob_df, aes(x = prob, fill = actual)) +
geom_histogram(bins = 50, alpha = 0.6, position = "identity") +
facet_wrap(~model, ncol = 1) +
scale_fill_manual(values = c("0" = "#ef4444", "1" = "#2563eb"),
labels = c("0" = "Non-converter", "1" = "Converter")) +
labs(title = "Predicted Probability Distribution",
x = "P(Conversion = 1)", y = "Count", fill = "Actual") +
theme_minimal()
ggsave("plots/xgboost/probability_distribution.png", p_probs, width = 9, height = 7, dpi = 150)
## Save Stage
xgb.save(model_A, "plots/xgboost/model_A.json")
xgb.save(model_B, "plots/xgboost/model_B.json")
cat("\n=== COMPLETE ===\n")
cat("Outputs saved to plots/xgboost/\n")
