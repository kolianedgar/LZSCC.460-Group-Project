# ==============================================================================
# ROC Curve and AUC Calculation
# ==============================================================================
# Install pROC if you don't have it: install.packages("pROC")
library(pROC)
# Calculate ROC curve
roc_obj <- roc(y_test, probs)
# Print AUC value
print(paste("AUC :", round(auc(roc_obj), 4)))
# Plot ROC curve
if (!dir.exists("plots")) dir.create("plots")
png("plots/14_roc_curve.png", width = 800, height = 800, res = 150)
plot(roc_obj, col = "#3498db", lwd = 3, main = "ROC Curve for Logistic Regression")
abline(a = 1, b = -1, lty = 2, col = "gray") # Diagonal reference line
dev.off()
print("ROC curve saved as plots/14_roc_curve.png")
# Objective 3: Statistical Modelling (Logistic Regression)
library(dplyr)
library(ggplot2)
library(broom)
library(caret)
library(pROC)
source("utils/utils.R")
source("01_preprocessing.R")
set_script_wd()
marketing_data <- read.csv("marketing.csv")
# Apply preprocessing
prep_stat <- preprocess_data(
data       = marketing_data,
target_col = "Conversion",
id_cols    = "CustomerID",
filter_col = "ConversionRate",
filter_min = 0,
filter_max = 1,
train_prop = 0.8,
stratify   = TRUE,
seed       = 123,
model_type = "glmnet"
)
# Train model with observation weights for class imbalance
train_df <- as.data.frame(prep_stat$X_train)
train_df$Conversion <- prep_stat$y_train
logistic_model <- glm(
Conversion ~ .,
data = train_df,
family = quasibinomial(link = "logit"),
weights = prep_stat$obs_weights
)
# Model Evaluation on Test Data (Metrics & ROC)
test_df <- as.data.frame(prep_stat$X_test)
y_test <- prep_stat$y_test
probs <- predict(logistic_model, newdata = test_df, type = "response")
preds <- factor(ifelse(probs > 0.5, "1", "0"), levels = levels(y_test))
conf_matrix <- confusionMatrix(preds, y_test, positive = "1")
roc_obj <- roc(y_test, probs, quiet = TRUE)
print("==================================")
print("==================================")
print("==================================")
print("Model Evaluation on Test Data")
print(paste("Accuracy          :", round(conf_matrix$overall["Accuracy"], 4)))
print(paste("Recall            :", round(conf_matrix$byClass["Sensitivity"], 4)))
print(paste("Specificity       :", round(conf_matrix$byClass["Specificity"], 4)))
print(paste("Balanced Accuracy :", round(conf_matrix$byClass["Balanced Accuracy"], 4)))
print(paste("AUC               :", round(auc(roc_obj), 4)))
# Plot and save ROC curve
if (!dir.exists("plots")) dir.create("plots")
png("plots/14_roc_curve.png", width = 800, height = 800, res = 150)
plot(roc_obj, col = "#3498db", lwd = 3, main = "ROC Curve for Logistic Regression")
abline(a = 1, b = -1, lty = 2, col = "gray") # Diagonal reference line
dev.off()
print("ROC curve saved as plots/14_roc_curve.png")
# Model Interpretation
# Extract and visualize Odds Ratios
model_results <- tidy(logistic_model, conf.int = TRUE) %>%
filter(term != "(Intercept)") %>%
mutate(
Odds_Ratio = exp(estimate),
Conf_Low = exp(conf.low),
Conf_High = exp(conf.high),
Significant = ifelse(p.value < 0.05, "Yes", "No")
) %>%
arrange(p.value)
print("==================================")
print("==================================")
print("==================================")
print("Top Drivers of Customer Conversion")
print(head(model_results %>% select(term, Odds_Ratio, p.value, Significant), 10))
# Save Forest Plot
p_forest <- ggplot(model_results, aes(x = reorder(term, Odds_Ratio), y = Odds_Ratio, color = Significant)) +
geom_point(size = 3) +
geom_errorbar(aes(ymin = Conf_Low, ymax = Conf_High), width = 0.2) +
geom_hline(yintercept = 1, linetype = "dashed", color = "red", size = 0.8) +
coord_flip() +
scale_color_manual(values = c("Yes" = "#2ecc71", "No" = "gray60")) +
labs(
title = "Key Drivers of Customer Conversion: Logistic Regression",
subtitle = "Odds Ratios with 95% Confidence Intervals",
x = "Features",
y = "Odds Ratio (Impact on Conversion)"
) +
theme_minimal(base_size = 14) +
theme(legend.position = "bottom", panel.grid.minor = element_blank())
ggsave("plots/13_statistical_drivers_forest.png", plot = p_forest, width = 10, height = 8, bg = "white")
print("Forest plot saved as plots/13_statistical_drivers_forest.png")
